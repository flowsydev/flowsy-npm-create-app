{
  "realm": "example",
  "enabled": true,
  "displayName": "Example Realm",
  "sslRequired": "none",
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 300,
  "roles": {
    "realm": [
      {
        "name": "operador",
        "description": "Operador de instalaciones. Acceso de lectura a sistemas operativos y registro de actividades en campo."
      },
      {
        "name": "tecnico-especialista",
        "description": "Técnico especialista. Acceso a datos técnicos, diagnósticos de equipo e informes de mantenimiento."
      },
      {
        "name": "supervisor-area",
        "description": "Supervisor de área. Acceso a reportes de producción, gestión de turnos y seguimiento de KPIs operativos."
      },
      {
        "name": "auditor-hse",
        "description": "Auditor de Health, Safety & Environment. Acceso a registros de seguridad, incidentes y cumplimiento normativo."
      },
      {
        "name": "gerente-unidad",
        "description": "Gerente de unidad de negocio. Acceso completo a dashboards ejecutivos, aprobación de presupuestos y gestión de personal."
      }
    ]
  },
  "clients": [
    {
      "clientId": "pemex-web-app",
      "name": "Pemex Web Application",
      "description": "Aplicación web de frontend con autenticación basada en sesión (Cookie). Obtiene tokens de Keycloak y los adjunta a las peticiones hacia pemex-web-api.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*",
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "pemex-web-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "pemex-web-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "pemex-web-api",
      "name": "Pemex Web API",
      "description": "Aplicación web de backend que valida tokens JWT Bearer emitidos por Keycloak. No realiza flujos de autenticación propios; recibe el token que pemex-web-app obtiene en nombre del usuario.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    }
  ],
